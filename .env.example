# Supabase (required for auth and database)
# 1. Copy this file: cp .env.example .env.local
# 2. Get URL and anon key: Supabase Dashboard → Project → Settings → API
# 3. Paste real values below. Never commit .env.local or expose service_role key.
# URL must be the API URL (https://...supabase.co), NOT the PostgreSQL connection string.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (required for auth redirect, checkout, QR codes). Production: https://www.puyer.org
# For local dev: NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://www.puyer.org

# Site URL for SEO (metadata, sitemap, robots). Default: https://www.puyer.org
# NEXT_PUBLIC_SITE_URL=https://www.puyer.org

# Optional: for server-only operations (e.g. webhooks, admin). Do not add to client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (required for Pay button and webhooks)
# STRIPE_SECRET_KEY=sk_...   # Platform account (Connect)
# STRIPE_WEBHOOK_SECRET=whsec_...   # Platform webhook (checkout.session.completed, subscription)
# STRIPE_WEBHOOK_SECRET_CONNECT=whsec_...   # Connect webhook (payout.paid from connected accounts)
# STRIPE_CONNECT_COUNTRY=GB  # Country for connected accounts: GB (UK), US, DE, FR. Match your Stripe region.

# Resend (Phase 7: send invoice & reminders)
# Get API key: https://resend.com/api-keys. For dev, use onboarding@resend.dev; for prod, verify your domain.
# RESEND_API_KEY=re_4ByfqgWV_9TTwGj6UQAoKoYQQHzVm84uh
# EMAIL_FROM=Puyer <onboarding@resend.dev>  # Optional; default: Puyer <onboarding@resend.dev>
# MAILING_ADDRESS=Your business address  # Required for CAN-SPAM; shown in email footer. Default: Puyer · support@puyer.org
# UNSUBSCRIBE_SECRET=your-random-secret  # For signing unsubscribe links. Optional; falls back to CRON_SECRET.
# RESEND_WEBHOOK_SECRET=whsec_...   # Inbound emails: signing secret from Resend Dashboard → Webhooks

# Reminders rate limit: 1 per N hours per invoice. 0 = no limit (debug only).
# REMINDER_RATE_LIMIT_HOURS=24

# Cron: secret for /api/cron/reminders (auto-reminders). Vercel Cron sends this as Bearer token.
# CRON_SECRET=your-random-secret

# Login OTP: secret for hashing OTP codes. Optional; fallback exists.
# LOGIN_OTP_SECRET=your-random-secret

# Login "remember 30 days" cookie: signing secret. Optional; uses CRON_SECRET or fallback.
# LOGIN_VERIFY_SECRET=your-random-secret

# Demo invoices: salt for IP hashing (rate limit). Optional; default fallback exists.
# DEMO_RATE_LIMIT_SECRET=your-random-secret

# Integrations: Calendar (Google). Required for "Connect Google Calendar" in Settings.
# Create OAuth 2.0 credentials in Google Cloud Console: APIs & Services → Credentials → Create OAuth client ID (Web application).
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/integrations/calendar/callback/google
# GOOGLE_CALENDAR_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-xxx

# Integrations: Calendar (Microsoft/Outlook). Required for "Connect Microsoft Calendar" in Settings.
# Register app in Azure Portal: Microsoft Entra ID → App registrations → New. Redirect URI (Web): ${NEXT_PUBLIC_APP_URL}/api/integrations/calendar/callback/microsoft
# API permissions: Calendars.Read (delegated), grant admin consent if needed. Create client secret under Certificates & secrets.
# AZURE_CLIENT_ID=xxx
# AZURE_CLIENT_SECRET=xxx
# AZURE_TENANT_ID=common  # or your tenant id; "common" = multi-tenant

# INTEGRATION_ENCRYPTION_KEY=64-hex-chars  # 32 bytes for AES-256; or use a passphrase (derived with scrypt). Required for both Google and Microsoft calendar.
